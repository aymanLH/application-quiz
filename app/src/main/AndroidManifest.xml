<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- INTERNET permission for AI mode (Step 9) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.QuizApp"
        android:supportsRtl="true">

        <!-- HOME SCREEN — the MAIN intent-filter marks it as launcher -->
        <activity android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register all other activities now to avoid errors later -->
        <activity android:name=".QuizActivity"      android:exported="false" />
        <activity android:name=".ResultActivity"    android:exported="false" />
        <activity android:name=".LeaderboardActivity" android:exported="false" />
        <activity android:name=".AISetupActivity"    android:exported="false" />

    </application>
</manifest>